dotnet_diagnostic.AsyncFixer06.severity = error # Task<T> to Task implicit conversion

# ReSharper properties
resharper_csharp_allow_far_alignment = true
resharper_int_align_switch_sections = true

[Tests/**.{cs,vb}]
# generate messages mostly for Test*<T> methods, which we don't want to change
dotnet_diagnostic.ide0001.severity = none # IDE0001: Simplify name
# test code uses lambdas-in-locals where local functions cannot carry anonymous-type returns
dotnet_diagnostic.IDE0039.severity = none # IDE0039: Use local function
# casts used a lot in test linq expressions
dotnet_diagnostic.ide0004.severity = none # IDE0004: Remove unnecessary cast

dotnet_diagnostic.IDE0051.severity = none # IDE0051: Remove unused private members

# pattern matching cannot be used in expression trees, so allow local linq and db linq to look the same
dotnet_diagnostic.IDE0078.severity = none # IDE0078: Use pattern matching
dotnet_diagnostic.IDE0083.severity = none # IDE0083: Use pattern matching (not operator)

