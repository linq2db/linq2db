<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<RootNamespace>LinqToDB.CLI</RootNamespace>
		<AssemblyName>dotnet-linq2db</AssemblyName>
		<TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
		<OutputType>Exe</OutputType>
		<GenerateDocumentationFile>false</GenerateDocumentationFile>
		<SignAssembly>False</SignAssembly>
		<RollForward>Major</RollForward>
		<SelfContained>false</SelfContained>
		<!--
		Mirrors ToolPackageRuntimeIdentifiers (see below). RuntimeIdentifiers drives
		restore (so per-RID assets exist in project.assets.json); ToolPackageRuntimeIdentifiers
		drives pack (so the SDK emits the per-RID tool nupkgs + pointer package).
		-->
		<RuntimeIdentifiers>win-x64;win-x86;win-arm64;linux-x64;linux-arm64;osx-arm64;osx-x64</RuntimeIdentifiers>
	</PropertyGroup>

	<PropertyGroup Label="Nuget">
		<PackAsTool>true</PackAsTool>
		<PackageId>linq2db.cli</PackageId>
		<ToolCommandName>dotnet-linq2db</ToolCommandName>
		<!--
		Per-RID tool packages (.NET 10 SDK feature). dotnet pack produces a thin
		pointer package under PackageId + one sub-package per RID; dotnet tool install
		-g linq2db.cli picks the sub-package matching the user's SDK architecture by
		default. Microsoft.Jet.OLEDB is the only strictly 32-bit-only provider and
		needs the win-x86 variant. Other providers (Microsoft.ACE OLE DB, SQL Server
		Compact Edition, SAP HANA) just need the tool bitness to match the installed
		driver bitness, so users install the matching x86 or x64 variant via the SDK
		arch flag (see readme.md and the CLI help text for the full guidance).
		-->
		<ToolPackageRuntimeIdentifiers>win-x64;win-x86;win-arm64;linux-x64;linux-arm64;osx-arm64;osx-x64</ToolPackageRuntimeIdentifiers>

		<Title>LINQ to DB command-line tools</Title>
		<Description>LINQ to DB CLI is a dotnet tool for Linq To DB database model scaffolding.</Description>
		<PackageTags>$(PackageTags);cli</PackageTags>
		<PackageIcon>icon.png</PackageIcon>
		<PackageReadmeFile>readme.md</PackageReadmeFile>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageProjectUrl>https://linq2db.github.io/</PackageProjectUrl>

		<EnablePackageValidation>false</EnablePackageValidation>
	</PropertyGroup>

	<ItemGroup Label="Nuget">
		<None Include="readme.md"             Pack="true" PackagePath="readme.md"        />
		<None Include="..\..\Nuget\icon.png"  Pack="true" PackagePath="icon.png"         />
	</ItemGroup>

	<ItemGroup>
		<EmbeddedResource Include="Template.tt" />

		<ProjectReference Include="..\LinqToDB.Scaffold\LinqToDB.Scaffold.csproj" />

		<PackageReference Include="Microsoft.CodeAnalysis.CSharp" />
		<PackageReference Include="Microsoft.Extensions.DependencyModel" />
		<PackageReference Include="Mono.TextTemplating" />

		<!--providers-->
		<PackageReference Include="Microsoft.Data.SQLite" />
		<PackageReference Include="Microsoft.Data.SqlClient" />
		<PackageReference Include="FirebirdSql.Data.FirebirdClient" />
		<PackageReference Include="MySqlConnector" />
		<PackageReference Include="Oracle.ManagedDataAccess.Core" />
		<PackageReference Include="Npgsql" />
		<PackageReference Include="AdoNetCore.AseClient" />
		<PackageReference Include="System.Data.Odbc" />
		<PackageReference Include="System.Data.OleDb" />
		<PackageReference Include="ClickHouse.Driver" />
		<PackageReference Include="Octonica.ClickHouseClient" />
		<PackageReference Include="DuckDB.NET.Data.Full" />
		<PackageReference Include="Ydb.Sdk" />

		<AdditionalFiles Include="PublicAPI.*.txt" />
	</ItemGroup>
</Project>
