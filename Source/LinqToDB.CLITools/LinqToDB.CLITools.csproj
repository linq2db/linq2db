<Project Sdk="Microsoft.NET.Sdk">
	<Import Project="..\..\Build\linq2db.Source.props" />

	<PropertyGroup>
		<AssemblyName>linq2db.Tools</AssemblyName>
		<RootNamespace>LinqToDB.Tools</RootNamespace>

		<DocumentationFile>bin\$(Configuration)\$(TargetFramework)\linq2db.Tools.xml</DocumentationFile>
		<TargetFrameworks>netcoreapp3.1</TargetFrameworks>
		<OutputType>Exe</OutputType>
		<WarningsAsErrors>true</WarningsAsErrors>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\LinqToDB.CodeGen\LinqToDB.CodeGen.csproj" />

		<PackageReference Include="Microsoft.Extensions.Configuration.Json" />

		<PackageReference Include="Humanizer.Core" />

		<!--providers-->
		<PackageReference Include="System.Data.SqlClient" />
		<PackageReference Include="dotMorten.Microsoft.SqlServer.Types" />

		<PackageReference Include="System.Data.SQLite.Core" />
		
		<PackageReference Include="Npgsql" />

	</ItemGroup>

	<ItemGroup>
	  <None Update="pg11.json">
	    <CopyToOutputDirectory>Always</CopyToOutputDirectory>
	  </None>
	  <None Update="sqlite.json">
	    <CopyToOutputDirectory>Always</CopyToOutputDirectory>
	  </None>
	  <None Update="sql2017.json">
	    <CopyToOutputDirectory>Always</CopyToOutputDirectory>
	  </None>
	</ItemGroup>

	<ItemGroup>
	  <Folder Include="Configuration\" />
	</ItemGroup>
</Project>
