<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
	<!--
	Packable project for the linq2db.Analyzers NuGet. Imports the ROOT props (shared Nuget metadata, version,
	signing) and NOT Source/Directory.Build.props (Source-tree banned-symbols / PublicAPI / 5-TFM list don't
	apply to a Roslyn component). Packs both this assembly and the sibling analyzer assembly into the package.
	-->
	<Import Project="$(MSBuildThisFileDirectory)\..\..\Directory.Build.props" />
	<!-- Shared Roslyn-component settings for both analyzer projects (after root props, so it overrides the multi-TFM list). -->
	<Import Project="$(MSBuildThisFileDirectory)\..\Analyzers.Common.props" />
</Project>
