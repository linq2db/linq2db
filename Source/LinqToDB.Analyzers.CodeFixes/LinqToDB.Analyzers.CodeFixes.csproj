<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<!-- Code-fix assembly for the user-facing analyzers. Not packed on its own: it is bundled into the
		     linq2db package by Source/LinqToDB/LinqToDB.csproj (under analyzers/dotnet/roslyn4.8/cs).
		     Shared Roslyn-component settings + polyfills live in ..\Analyzers.Common.props. -->
		<IsPackable>false</IsPackable>
	</PropertyGroup>

	<ItemGroup>
		<!-- The shared compat sources target the runtime library and aren't needed by a Roslyn component. -->
		<Compile Remove="$(MSBuildThisFileDirectory)..\..\Source\Shared\*.cs" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" PrivateAssets="all" />
	</ItemGroup>

	<ItemGroup>
		<!-- Build the analyzer assembly alongside this code-fix assembly; no dependency leaks (PrivateAssets). -->
		<ProjectReference Include="..\LinqToDB.Analyzers\LinqToDB.Analyzers.csproj" PrivateAssets="all" />
	</ItemGroup>

</Project>
