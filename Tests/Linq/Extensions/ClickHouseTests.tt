<#+
void GenerateJoinHint(string test, string hint, bool obsolete = false)
{
#>
<#+ if (obsolete) { #>
#pragma warning disable CS0618 // Type or member is obsolete
<#+ } #>
		[Test]
		public void Join<#= test #>HintTest([IncludeDataSources(true, TestProvName.AllClickHouse)] string context)
		{
			using var db = GetDataContext(context);

			var q =
				from c in db.Child
				join p in db.Parent.AsClickHouse().Join<#= test #>Hint() on c.ParentID equals p.ParentID into g
				from p in g.DefaultIfEmpty()
				select p;

			_ = q.ToList();

			Assert.That(LastQuery, Contains.Substring($"<#= hint #> JOIN"));
		}
