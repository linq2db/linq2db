<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>net10.0</TargetFrameworks>
		<OutputType>Exe</OutputType>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>

		<RootNamespace>Tests.LocalTestGenerator</RootNamespace>
		<AssemblyName>linq2db.Tests.LocalTestGenerator</AssemblyName>
		<GenerateDocumentationFile>false</GenerateDocumentationFile>
		<IsPackable>false</IsPackable>
		<IsTestProject>false</IsTestProject>
		<IsTestingPlatformApplication>false</IsTestingPlatformApplication>
		<DisableTestingPlatformServerCapability>true</DisableTestingPlatformServerCapability>
		<NoWarn>$(NoWarn);RS0030</NoWarn>
	</PropertyGroup>

	<ItemGroup>
		<ProjectCapability Remove="TestContainer" />
		<ProjectCapability Remove="TestingPlatformServer" />
		<ProjectCapability Remove="TestingPlatformServer.ExitOnProcessExitCapability" />
		<ProjectCapability Remove="TestingPlatformServer.UseListTestsOptionForDiscoveryCapability" />
		<ProjectReference Include="..\Base\Tests.Base.csproj" />
	</ItemGroup>
</Project>
