<Project Sdk="Microsoft.NET.Sdk">

	<Import Project="Tests.NHibernate.props" />

	<PropertyGroup>
		<!-- Test on the latest .NET plus .NET Framework (net462); the netfx leg is Windows-only. -->
		<TargetFrameworks>net462;net10.0</TargetFrameworks>
		<!-- Match the source's Testing-config override (net10.0 only) so a -c Testing build stays single-TFM and
		     doesn't try net462 against a net10.0-only source. -->
		<TargetFrameworks Condition="'$(Configuration)' == 'Testing'">net10.0</TargetFrameworks>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\Source\LinqToDB.NHibernate\LinqToDB.NHibernate.NH5.csproj" />
	</ItemGroup>

</Project>
