<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Compile-only regression gate for the CLI scaffolder's F# output (issue #1553) - NRT-enabled variant.
    The committed .fs files are produced by scaffolding with target-language f# and nrt=true, and must compile
    under F# 9 nullness (Nullable=enable): nullable reference members carry a `| null` annotation. The
    nullness-disabled (nrt=false) variant is Tests.FSharp.Scaffold.NoNrt.fsproj; the two together give both-mode
    coverage. CI detects generator regressions when either project fails to build. Regenerate both via
    generate.ps1.
  -->

  <PropertyGroup>
    <AssemblyName>linq2db.Tests.FSharp.Scaffold</AssemblyName>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>9</LangVersion>
    <WarningLevel>5</WarningLevel>
    <!-- F# 9 nullness on: the nrt=true baselines must be nullness-clean -->
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <!-- one generated file per (provider) baseline; F# requires explicit ordered compile items.
         each file uses a distinct namespace (Tests.FSharp.Scaffold.<Provider>) so the TestDataDB
         context names don't collide in the single assembly. Regenerate via generate.ps1. -->
    <Compile Include="SQLite\TestDataDB.fs" />
    <Compile Include="PostgreSQL\TestDataDB.fs" />
    <Compile Include="SqlServer\TestDataDB.fs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Source\LinqToDB\LinqToDB.csproj" />
    <ProjectReference Include="..\..\Source\LinqToDB.FSharp\LinqToDB.FSharp.fsproj" />
    <PackageReference Include="FSharp.Core" />
    <!-- baselines are generated with prefer-provider-types, so they reference provider-specific CLR
         types (NpgsqlTypes.*, Microsoft.SqlServer.Types.*); these packages make them resolve, mirroring
         what a real F# app scaffolded against these providers must reference -->
    <PackageReference Include="Npgsql" />
    <PackageReference Include="Microsoft.SqlServer.Types" />
  </ItemGroup>

</Project>
