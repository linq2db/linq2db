<#@ assembly name="$(LinqToDBT4SharedTools)linq2db.dll"                                 #>
<#@ assembly name="$(LinqToDBT4SharedTools)Microsoft.Bcl.AsyncInterfaces.dll"           #>
<#@ include file="$(LinqToDBT4TemplatesPath)PluralizationService.ttinclude" once="true" #>
<#@ include file="ConnectionStrings.ttinclude"                              once="true" #>
<#
	EnableNullableReferenceTypes = true;
	GenerateDatabaseInfo         = false;

	// temporary, see SQLite.Runtime.props notes
	var sqliteRuntimesPath = Host.ResolveAssemblyReference("$(LinqToDBT4SharedTools)");
	Environment.SetEnvironmentVariable("PreLoadSQLite_BaseDirectory", Path.Combine(sqliteRuntimesPath, "sds"));
#>
