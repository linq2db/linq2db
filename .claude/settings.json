{
    "model": "claude-opus-4-7[1m]",
    "effortLevel": "high",
    "alwaysThinkingEnabled": true,
    "permissions": {
		"allow": [
			"Bash(git checkout *)",
			"Bash(git add *)",
			"Bash(git commit *)",
			"Bash(git push *)",
			"Bash(gh api *)",
			"Bash(gh pr *)"
		],
        "deny": [
        ]
    },
    "spinnerVerbs": {
        "verbs": [
            "AI-slopping"
        ],
        "mode": "replace"
    },
    "statusLine": {
        "type": "command",
        "command": "node .claude/statusline.js",
        "padding": 0
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node .claude/hooks/check-bash-chain.js"
                    }
                ]
            }
        ]
    }
}
